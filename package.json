{
  "name": "inspectctl",
  "version": "0.0.1",
  "description": "MCP server giving AI agents debugger-level visibility into Node/Python processes",
  "type": "module",
  "bin": {
    "inspectctl": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "target": "node --inspect=9229 examples/target.cjs",
    "bundle": "node scripts/bundle.mjs",
    "build:exe": "node scripts/build-exe.mjs",
    "build:macos": "node scripts/build-macos.mjs",
    "build:macos:dmg": "node scripts/build-macos.mjs --dmg",
    "build:linux": "node scripts/build-linux.mjs"
  },
  "keywords": [
    "mcp",
    "debugger",
    "cdp",
    "ai",
    "inspect"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "chrome-remote-interface": "^0.33.2",
    "express": "^5.2.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/chrome-remote-interface": "^0.31.14",
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.0",
    "esbuild": "^0.28.1",
    "postject": "^1.0.0-alpha.6",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
